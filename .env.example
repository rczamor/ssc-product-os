# Single-quote any value containing shell metacharacters ($ ` " etc.) so the
# `set -a; . ./.env.local` prefix can't expand them, e.g. SSC_PASSWORD='a$b'.
# Better: run runner commands via `node bin/run.mjs npx tsx runner/<x>.ts` —
# it loads this file in-process (no shell expansion) and sets NODE_EXTRA_CA_CERTS.
#
# ── Deployed app (set these in Vercel → Project → Settings → Environment Variables)
# Neon Postgres connection string (postgres://...@...neon.tech/...?sslmode=require)
DATABASE_URL=
# Linear API key (app pushes/reads tickets server-side; runner drafts + seeds).
# Also set in Vercel env. Take-home work is scoped to the SSC-ProductOS project.
LINEAR_API_KEY=
# Shared secret for the inbound Linear webhook (POST /linear/webhook). Set it to
# the secret Linear shows when you create the webhook; the endpoint verifies the
# Linear-Signature HMAC against it. Optional — only needed for real-time Linear→app sync.
LINEAR_WEBHOOK_SECRET=
# Admin UI login — set both to whatever you want; you log in with these.
ADMIN_EMAIL=
ADMIN_PASSWORD=
# Optional display name shown in the app header (defaults to the admin email).
ADMIN_DISPLAY_NAME=
# Random secret used to sign the session cookie (openssl rand -hex 32)
SESSION_SECRET=

# ── Runner only (local Claude Code environment; NEVER deployed, never committed)
# SecurityScorecard demo credentials from the take-home exercise
SSC_EMAIL=
SSC_PASSWORD=
# Langfuse project keys (cloud.langfuse.com → Project Settings → API Keys)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
# Set DATABASE_URL here TOO if the runner should read/write the deployed Neon
# database (required for the admin-UI queue → poll loop). Without it the runner
# uses a local file-backed PGlite at PGLITE_DATA_DIR below.

# ── Local development / tests
# Use in-process PGlite instead of Neon (tests set this automatically)
USE_PGLITE=
# PGlite storage dir when no DATABASE_URL is set. Default ".pglite-data" so the
# runner's many short-lived processes share one database; set "" for in-memory.
PGLITE_DATA_DIR=.pglite-data
# Seed demo data on first PGlite connection (e2e/demo only)
PGLITE_SEED=
# CDP port for the persistent browser (runner/browse.ts); default 9222
BROWSE_PORT=
# CA bundle for environments behind a TLS-intercepting proxy
NODE_EXTRA_CA_CERTS=
