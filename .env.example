# ── Deployed app (set these three in Vercel → Project → Settings → Environment Variables)
# Neon Postgres connection string (postgres://...@...neon.tech/...?sslmode=require)
DATABASE_URL=
# Shared password for the admin UI login
ADMIN_PASSWORD=
# Random secret used to sign the session cookie (openssl rand -hex 32)
SESSION_SECRET=

# ── Runner only (local Claude Code environment; NEVER deployed, never committed)
# SecurityScorecard demo credentials from the take-home exercise
SSC_EMAIL=
SSC_PASSWORD=
# Langfuse project keys (cloud.langfuse.com → Project Settings → API Keys)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ── Local development / tests
# Use in-process PGlite instead of Neon (tests set this automatically)
USE_PGLITE=
# Seed demo data on first PGlite connection (e2e uses this)
PGLITE_SEED=
# CA bundle for environments behind a TLS-intercepting proxy
NODE_EXTRA_CA_CERTS=
